http://:8080 {
    # 1. API route (Must be matched first)
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy {$GOTENBERG_URL} {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            
            # Disable buffering for large document uploads
            flush_interval -1
        }
    }

    # 2. Static UI Files
    handle {
        root * /usr/share/caddy
        encode gzip
        try_files {path} /index.html
        file_server
    }
}
