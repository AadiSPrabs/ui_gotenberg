{
    # Bind to both 80 and 443
    http_port 80
    https_port 443
}

# HTTP and HTTPS server
:80, :443 {
    # Self-signed certs for local IP/domain if no domain is provided
    tls internal

    # 1. API route (Must be matched first)
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy localhost:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            
            # Disable buffering for large document uploads
            flush_interval -1
        }
    }

    # 2. Static UI Files
    handle {
        root * /srv
        encode gzip
        try_files {path} /index.html
        file_server
    }
}
